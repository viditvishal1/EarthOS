# Argus environment template
# Copy to .env.local — never commit secrets

# --- Required for production persistence (server-side only) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Optional Supabase keys (prototype / client — not for open RLS writes)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Embeddings: gemini-embedding-001 with 768-dim output (matches vector(768) column).
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Source API keys (optional unless noted) ---
# AISHUB_API_KEY — REQUIRED for live vessel (AIS) positions
AISHUB_API_KEY=
PRODUCTHUNT_API_TOKEN=
TOMTOM_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Conflict / geopolitical events
# ACLED: free with registration — https://developer.acleddata.com (key + registered email)
ACLED_API_KEY=
ACLED_EMAIL=
# UCDP: free access token — https://ucdp.uu.se/apidocs/
UCDP_ACCESS_TOKEN=
# ReliefWeb ships via its public RSS feed — keyless, no configuration needed.

# Macro / economics
# FRED: free key — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# EIA (energy): free key — https://www.eia.gov/opendata/register.php
EIA_API_KEY=
# World Bank is keyless — no configuration needed.

# Live channels use curated officially-public streams — keyless, no configuration needed.

# --- Redis / Upstash (REQUIRED for production live-data cache) ---
# Preferred names (server-only — never NEXT_PUBLIC_):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel Upstash integration fallback (app accepts these if UPSTASH_* unset):
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Do NOT use KV_REST_API_READ_ONLY_TOKEN for cache writes.

# --- Live data scheduler (server-only) ---
# CRON_SECRET protects GET /api/cron/live — generate with: openssl rand -hex 32
# Configure in Vercel (Production + Preview as needed). Redeploy after changes.
CRON_SECRET=

# Public deployment URL (workers + Supabase Cron Vault — not exposed to browser)
ARGUS_APP_URL=https://your-app.vercel.app

# Seed interval for optional Rust worker (seconds). Default 90.
# Use >=120 when Supabase Cron (every 2 min) is also active.
LIVE_SEED_INTERVAL_SECS=90

# --- Cloudflare R2 (optional — raw payload archive) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=argus-raw

# --- ClickHouse (optional — production analytics only) ---
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=earthos

# --- OpenSearch (optional — Phase 2) ---
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# --- Live data / World Monitor-style seed-read split ---
# Redis vars above are mandatory for production live cache.
# Connectors without keys: ISS (wheretheiss.at), curated webcams, USGS, World Bank, ReliefWeb RSS.

# Wingbits global ADS-B (fast single-call flight layer — optional but recommended)
WINGBITS_API_KEY=

# Optional Railway relay proxy (OpenSky OAuth + Wingbits + rate-limit isolation)
WS_RELAY_URL=
RELAY_SHARED_SECRET=
RELAY_AUTH_HEADER=x-relay-key

# Windy Webcams v3 — expands CCTV grid beyond curated YouTube streams (optional)
WINDY_WEBCAMS_API_KEY=

# TomTom traffic overlays (optional)
# TOMTOM_API_KEY= above

# Background workers (Railway/Fly — optional fallback scheduler)
# ARGUS_APP_URL and LIVE_SEED_INTERVAL_SECS documented above
USGS_POLL_INTERVAL_SECS=300

# --- Ingestion / admin (server-only) ---
# ARGUS_* preferred; legacy EARTHOS_* names still accepted for CRON_SECRET fallbacks.
ARGUS_INGEST_SECRET=
ARGUS_ADMIN_SECRET=
EARTHOS_INGEST_URL=http://localhost:3000

# --- Feature flag overrides (optional) ---
# EARTHOS_FLAG_STRICT_RATE_LIMITS=true
# EARTHOS_FLAG_R2_ARCHIVE=false

# --- Cost / quota thresholds (optional overrides) ---
# EARTHOS_QUOTA_WARN_PCT=60
# EARTHOS_QUOTA_REDUCE_PCT=75
# EARTHOS_QUOTA_PAUSE_PCT=85
