# Optional — copy to .env.local. No keys required for core features.

# AI Analyst + search briefings (Google Gemini free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Live AIS vessel positions
AISHUB_API_KEY=

# Product Hunt launches (GraphQL API token)
PRODUCTHUNT_API_TOKEN=

# Supabase persistence (run supabase/schema.sql first)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Upstash Redis event bus (REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# External connector ingest (Rust worker → /api/ingest)
EARTHOS_INGEST_SECRET=

# Optional Google Maps — Street View embed + traffic in City Digital Twin
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
