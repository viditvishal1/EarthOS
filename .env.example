# Argus environment — copy to .env.local (dev) or set in your host (Vercel/Docker).
# No keys are required for local dev; grouped by profile.

# ── Core (local dev) ─────────────────────────────────────────────────────────
# NODE_ENV=development
# ARGUS_APP_URL=http://localhost:3000

# ── Hosted profile (Vercel / production) ─────────────────────────────────────
# ARGUS_APP_URL=https://your-app.vercel.app
# CRON_SECRET=                        # Protects /api/cron/* — generate a strong random value
# ARGUS_API_SECRET=                     # Bearer token for private write APIs in production
# ARGUS_ADMIN_SECRET=                   # Admin PATCH /api/config/sources (alias: EARTHOS_ADMIN_SECRET)

# ── Supabase (optional persistence + auth) ───────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Browser auth (Phase 2 RLS)
# SUPABASE_URL=                         # Server alias for NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_PUBLISHABLE_KEY=             # Legacy alias for anon key
# SUPABASE_SERVICE_KEY=                 # Service role — server only, never NEXT_PUBLIC_*

# ── Cache / event bus (optional) ─────────────────────────────────────────────
# TELEGRAM_CHANNELS=disclosetv,breaking911  # Public Telegram channels (G06)
# TELEGRAM_CHANNELS=disclosetv,breaking911  # Public Telegram channels (G06)
# STRIPE_SECRET_KEY=                  # Billing (G47)
# STRIPE_WEBHOOK_SECRET=
# VAPID_PUBLIC_KEY=                   # Web Push (G19) — generate with: npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@example.com
# VALKEY_URL=redis://localhost:6379  # Docker self-host TCP cache (G43)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=                      # Vercel KV alias
# KV_REST_API_TOKEN=

# ── Self-host Postgres (Docker Compose) ──────────────────────────────────────
# DATABASE_URL=postgres://argus:argus@localhost:5432/argus

# ── AI providers (optional) ──────────────────────────────────────────────────
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# LMSTUDIO_BASE_URL=
# LMSTUDIO_MODEL=local-model

# ── Data provider keys (optional — unlock gated connectors) ──────────────────
# AISHUB_API_KEY=
# AISSTREAM_API_KEY=                   # WebSocket global AIS fallback (aisstream.io)
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
# ACLED_API_KEY=
# ACLED_EMAIL=
# UCDP_ACCESS_TOKEN=
# FRED_API_KEY=
# EIA_API_KEY=
# TOMTOM_API_KEY=
# MAPPLS_API_KEY=
# MAPMYINDIA_API_KEY=
# PRODUCTHUNT_API_TOKEN=
# NASA_FIRMS_MAP_KEY=
# WINDY_WEBCAMS_API_KEY=
# TFL_APP_KEY=
# WSDOT_ACCESS_CODE=
# YAHOO_FINANCE_ENABLED=true

# ── Ingest worker ────────────────────────────────────────────────────────────
# ARGUS_INGEST_SECRET=

# ── Object storage (optional R2 archive) ─────────────────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# ── Search / analytics (optional) ────────────────────────────────────────────
# OPENSEARCH_URL=
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
# CLICKHOUSE_URL=
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=earthos

# ── Quota thresholds (self-host / hosted) ────────────────────────────────────
# EARTHOS_QUOTA_WARN_PCT=60
# EARTHOS_QUOTA_REDUCE_PCT=75
# EARTHOS_QUOTA_PAUSE_PCT=85
# EARTHOS_QUOTA_EMERGENCY_PCT=95
# EARTHOS_QUOTA_CRITICAL_PCT=98
