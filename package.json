{
  "name": "argus",
  "version": "2.0.0",
  "private": true,
  "description": "Argus — an open intelligence operating system built on public data",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:e2e": "node scripts/start-e2e.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify:live-data": "node scripts/verify-live-data.mjs",
    "seed:cctv": "node scripts/seed-cctv.mjs",
    "preflight": "node scripts/preflight.mjs",
    "migrate-check": "node scripts/migrate-check.mjs",
    "staging-parity": "node scripts/staging-parity.mjs",
    "restore-drill": "node scripts/restore-drill.mjs",
    "build:ci": "npm run typecheck && npm test && npm run build",
    "release-gate": "node scripts/preflight.mjs && npm run typecheck && npm test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@upstash/redis": "^1.38.0",
    "fast-xml-parser": "^4.5.0",
    "lucide-react": "^0.469.0",
    "maplibre-gl": "^5.24.0",
    "marked": "^18.0.5",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3",
    "recharts": "^2.15.0",
    "satellite.js": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-grid-layout": "^1.3.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
